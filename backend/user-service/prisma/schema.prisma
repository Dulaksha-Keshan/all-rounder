// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  //  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// 1. INDEPENDENT USER TABLES
// ==========================================

model Student {
  uid             String   @id @unique
  // Profile Fields (Formerly in User)
  name            String
  email           String   @unique
  date_of_birth   DateTime
  contact_number  String?
  profile_picture String?
  is_active       Boolean  @default(true)
  is_frozen       Boolean  @default(false)

  // Student Specifics
  grade      String
  about      String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relationships
  school_id String
  school    School @relation(fields: [school_id], references: [school_id])

  skills Skill[]
}

model Teacher {
  uid String @id @unique

  // Profile Fields
  name            String
  email           String   @unique
  date_of_birth   DateTime
  contact_number  String?
  profile_picture String?
  is_active       Boolean  @default(true)

  // Teacher Specifics
  subject     String?
  designation String?
  // staff_id is often used as a visible ID, distinct from the database PK
  staff_id    String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relationships
  school_id String
  school    School @relation(fields: [school_id], references: [school_id])
}

model Admin {
  uid String @id @unique

  // Profile Fields
  name            String
  email           String   @unique
  adminType       UserType
  date_of_birth   DateTime
  contact_number  String?
  profile_picture String?
  is_active       Boolean  @default(true)

  // Admin Specifics
  staff_id   String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relationships
  school_id       String?
  school          School?       @relation(fields: [school_id], references: [school_id])
  organization_id String?
  organization    Organization? @relation(fields: [organization_id], references: [organization_id])
}

// ==========================================
// 2. SCHOOL & ORGANIZATIONS
// ==========================================

model School {
  school_id      String   @id @default(uuid())
  name           String
  address        String
  district       String
  student_count  Int?
  email          String
  contact_number String
  principal_name String?
  web_link       String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  // School now relates to these 3 independent tables separately
  students   Student[]
  teachers   Teacher[]
  admins     Admin[]
  eventHosts EventHost[]
}

model Organization {
  organization_id   String      @id @default(uuid())
  organization_name String
  contact_person    String
  website           String?
  admins            Admin[]
  eventHosts        EventHost[]
}

// ==========================================
// 3. SKILLS
// ==========================================

model Skill {
  skill_id   Int       @id @default(autoincrement())
  skill_name String
  category   String
  students   Student[]
}

model EventHost {
  id       String   @id @default(uuid())
  eventId  String // mongo ObjectId stored as string
  hostType HostType // SCHOOL or ORGANIZATION

  // One of these will be null depending on hostType
  schoolId       String?
  organizationId String?

  isPrimaryHost Boolean  @default(false)
  createdAt     DateTime @default(now())

  // Relations to existing models
  school       School?       @relation(fields: [schoolId], references: [school_id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [organization_id], onDelete: Cascade)

  // Prevent duplicate host mappings for same event
  @@unique([eventId, schoolId])
  @@unique([eventId, organizationId])
  @@index([eventId])
  @@index([schoolId])
  @@index([organizationId])
  @@map("event_hosts")
}

enum HostType {
  SCHOOL
  ORGANIZATION
}

enum UserType {
  STUDENT
  TEACHER
  SCHOOL_ADMIN
  ORG_ADMIN
  SUPER_ADMIN
}
